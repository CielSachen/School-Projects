{
  // Text Editor
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.tabSize": 2,
  "editor.formatOnSave": true,
  "files.insertFinalNewline": true,

  // C Support
  "C_Cpp.default.cStandard": "c99",
  "C_Cpp.default.includePath": ["${workspaceFolder}/**/include", "${workspaceFolder}/build/**"],
  "C_Cpp.doxygen.generatedStyle": "/**",
  "C_Cpp.codeAnalysis.clangTidy.enabled": true,

  // Python Support
  "python.analysis.autoImportCompletions": true,
  "python.analysis.fixAll": ["source.unusedImports", "source.convertImportFormat"],
  "python.analysis.typeCheckingMode": "strict",

  // TOML Support
  "evenBetterToml.schema.associations": { "ruff.toml": "http://json.schemastore.org/ruff" },

  // Prettier Extension
  "prettier.printWidth": 100,

  // Ruff Extension
  "ruff.configuration": "./ruff.toml",

  // C Files Only Settings
  "[c]": {
    // Text Editor
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit",
      "source.organizeImports": "explicit"
    },
    "editor.defaultFormatter": "ms-vscode.cpptools",
    "editor.tabSize": 4
  },

  // Python Files Only Settings
  "[python]": {
    // Text Editor
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit",
      "source.organizeImports": "explicit"
    },
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.tabSize": 4
  }
}
